# API Configuration
# Local dev
# VITE_API_BASE_URL=http://localhost:8008

# VPS production with dedicated API domain (recommended):
VITE_API_BASE_URL=https://api.ghouse-sourcing.com

# Alternative if you proxy API through the frontend domain:
# VITE_API_BASE_URL=/api

# Comma-separated user IDs that can update QC without label requirements
# and can use today through today - 5 days.
LabelExemptUsers=
