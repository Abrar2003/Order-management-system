NODE_ENV=production
PORT=8008

# Database
MONGO_URI=mongodb+srv://username:password@cluster.example.mongodb.net/OMS
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000

# Auth
JWT_SECRET=replace_with_a_strong_secret
ALLOW_PUBLIC_SIGNUP=false
AUTH_RATE_LIMIT_MAX_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_MS=900000

# API / reverse proxy behavior
TRUST_PROXY=true
FORCE_PUBLIC_DNS=false
JSON_BODY_LIMIT=10mb
URLENCODED_BODY_LIMIT=10mb
GENERIC_UPLOAD_MAX_FILE_SIZE=52428800

# CORS (comma-separated). Leave blank only if you intentionally allow all origins.
CORS_ORIGIN=https://oms.ghouse-sourcing.com,https://ghouse-sourcing.com
CORS_ALLOW_CREDENTIALS=false

# Google integrations (required for calendar/sheets sync features)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.ghouse-sourcing.com/google/callback
GOOGLE_REFRESH_TOKEN=
GCAL_CALENDAR_ID=
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_NAME=orders

# Wasabi object storage (optional, used for brand logos and uploaded source files)
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
WASABI_BUCKET=
WASABI_REGION=us-east-1
WASABI_ENDPOINT=s3.us-east-1.wasabisys.com
# Optional public base URL if you expose the bucket behind a CDN/custom domain
WASABI_PUBLIC_BASE_URL=

# Redis cache and BullMQ jobs
REDIS_CACHE_ENABLED=true
REDIS_JOBS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# Cache TTLs
CACHE_TTL_SHORT_SECONDS=60
CACHE_TTL_MEDIUM_SECONDS=300
CACHE_TTL_LONG_SECONDS=900

# PM2 process counts
PM2_WEB_INSTANCES=2
PM2_WORKER_INSTANCES=1

# Worker concurrency
ORDER_IMPORT_WORKER_CONCURRENCY=1
FILE_WORKER_CONCURRENCY=1
CALENDAR_WORKER_CONCURRENCY=1
CBM_WORKER_CONCURRENCY=2
IMAGE_WORKER_CONCURRENCY=1
